# Hallucination Hunter â€” environment configuration template.
# Copy this file to .env and replace placeholder values.
# The .env file is listed in .gitignore and must never be committed.

# â”€â”€ Active provider â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Which provider the pipeline uses. One of: gemini | openai | anthropic | grok
LLM_PROVIDER=gemini

# â”€â”€ Google Gemini (default â€” free tier, no credit card required) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Get your key at https://aistudio.google.com/app/apikey
# Free limits: gemini-2.5-flash-lite â†’ 1 000 req/day
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Options: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro

# â”€â”€ OpenAI â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
