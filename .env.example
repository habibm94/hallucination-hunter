# Hallucination Hunter — environment configuration template.
# Copy this file to .env and replace placeholder values.
# The .env file is listed in .gitignore and must never be committed.

# ── Active provider ────────────────────────────────────────────────────────────
# Which provider the pipeline uses. One of: gemini | openai | anthropic | grok
LLM_PROVIDER=gemini

# ── Google Gemini (default — free tier, no credit card required) ───────────────
# Get your key at https://aistudio.google.com/app/apikey
# Free limits: gemini-2.5-flash-lite → 1 000 req/day
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Options: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Options: gpt-4o-mini | gpt-4o

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Options: claude-haiku-4-5 | claude-sonnet-4-6

# ── Grok (xAI) ────────────────────────────────────────────────────────────────
# Free tier available — sign up at https://console.x.ai
XAI_API_KEY=
GROK_MODEL=grok-3-mini
# Options: grok-3-mini | grok-3
