# Hallucination Hunter — environment configuration template.
# Copy this file to .env and replace placeholder values.
# The .env file is listed in .gitignore and must never be committed.

# ------------------------------------------------------------------
# Development: Gemini (free tier, no credit card required)
# Get your key at https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use during development (default shown below)
# Options: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash-lite

# ------------------------------------------------------------------
# Optional providers — leave blank unless actively using them
# ------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# XAI_API_KEY=       # Grok — supported in Step 9
