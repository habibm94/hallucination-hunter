# Hallucination Hunter — Environment Variables
# Copy this file to .env and add your actual keys
# NEVER commit .env to GitHub

# Choose one (or both):
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Free alternative judge via Groq
GROQ_API_KEY=your_groq_api_key_here

# Model selection (default: gpt-4o)
JUDGE_MODEL=gpt-4o
# Options: gpt-4o | claude-sonnet-4-6 | llama3-70b-8192 (groq)
